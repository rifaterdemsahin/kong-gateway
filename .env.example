# Smart-Cost Multi-LLM Orchestrator — Environment Variables
# Copy this file to .env and fill in your keys.
#
# cp .env.example .env

# ── Demo mode (no API keys needed) ───────────────────────────────────────────
# Set to "true" to return simulated responses with cost estimates.
# Set to "false" to call real LLM APIs (requires keys below).
MOCK_MODE=true

# ── LLM API Keys (only needed when MOCK_MODE=false) ──────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
